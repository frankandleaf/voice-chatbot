# LLM Configuration (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o
LLM_DEVICE_NAME=firefly

# vLLM-Omni TTS Server
TTS_BASE_URL=http://localhost:8091/v1
TTS_API_KEY=not-needed
TTS_MODEL=fishaudio/s2-pro

# These are optional — only if you distribute a .env with real values
# VAD settings are in config.yaml
